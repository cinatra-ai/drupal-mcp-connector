{
  "name": "@cinatra-ai/drupal-mcp-connector",
  "version": "0.1.4",
  "license": "Apache-2.0",
  "files": [
    "src",
    "cinatra",
    "!src/__tests__/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./register": "./src/register.ts",
    "./settings-page": "./src/settings-page.tsx",
    "./setup-page": "./src/setup-page.tsx",
    "./mcp-handlers": "./src/mcp/handlers.ts",
    "./mcp-toolbox": "./src/mcp/toolbox.ts",
    "./mcp-module": "./src/mcp/module.ts",
    "./widget-chat-tool": "./src/widget-chat-tool.ts"
  },
  "scripts": {
    "test": "vitest",
    "lint": "eslint . --no-inline-config"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "10.4.1",
    "typescript": "5.9.3"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "vendor": {
      "key": "cinatra-ai",
      "name": "Cinatra"
    },
    "displayName": "Drupal MCP",
    "providesExternalMcpToolbox": true,
    "serverEntry": "./register",
    "requestedHostPorts": [
      "nango",
      "capabilities"
    ],
    "dependencies": [],
    "widgetStream": {
      "agentSlug": "drupal-content-editor",
      "relayAgentPackage": "@cinatra-ai/drupal-agent",
      "label": "Drupal",
      "subjectNoun": "node",
      "skillCapability": "widget-chat.drupal-content-editor",
      "contextFields": [
        {
          "key": "instanceId",
          "maxLength": 64
        },
        {
          "key": "nodeId",
          "maxLength": 32
        },
        {
          "key": "nodeBundle",
          "maxLength": 32
        },
        {
          "key": "nodeStatus",
          "maxLength": 32
        },
        {
          "key": "href",
          "maxLength": 500
        }
      ],
      "auth": {
        "tokenConfigKey": "drupal_widget_auth",
        "instancesConfigKey": "drupal",
        "requiredInstanceFields": [
          "id",
          "name",
          "nangoConnectionId"
        ]
      }
    }
  }
}
